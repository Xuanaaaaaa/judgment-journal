{
  "name": "judgment-journal",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:prep": "rm -rf .next/standalone/.next/static .next/standalone/public && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && cp .env .next/standalone/.env",
    "dist": "next build && npm run electron:prep && electron-builder --mac"
  },
  "build": {
    "appId": "com.judgmentjournal.app",
    "productName": "Judgment Journal",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "afterPack": "electron/after-pack.js",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dir",
      "identity": null
    }
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@base-ui/react": "^1.5.0",
    "ai": "^6.0.193",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.1",
    "shadcn": "^4.9.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
