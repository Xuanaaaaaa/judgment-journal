# 数据库连接（对应 docker-compose.yml）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/judgment_journal"

# Embedding 向量维度（跟随所选 embedding 模型；改值需重新 migration）
# 1536 = OpenAI text-embedding-3-small；部分国产模型为 1024
EMBEDDING_DIMENSIONS=1536

# AI 对话/解析模型 provider（anthropic | openai | openai-compatible）
# 实际密钥在设置页填写并存库，这里仅为本地开发可选默认值
# AI_PROVIDER=
# AI_API_KEY=
# AI_BASE_URL=

# Embedding provider（独立于对话模型；Anthropic 无 embedding，需用 openai 或兼容厂商）
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-3-small
